Function\n","def plot_history(history, model_name):\n","    \"\"\"Fungsi untuk visualisasi akurasi dan loss pelatihan\"\"\"\n","    acc = history.history['accuracy']\n","    val_acc = history.history['val_accuracy']\n","    loss = history.history['loss']\n","    val_loss = history.history['val_loss']\n","    epochs = range(1, len(acc) + 1)\n","\n","    plt.figure(figsize=(12, 5))\n","\n","    # Plot Akurasi\n","    plt.subplot(1, 2, 1)\n","    plt.plot(epochs, acc, 'b', label='Training Accuracy')\n","    plt.plot(epochs, val_acc, 'r', label='Validation Accuracy')\n","    plt.title(f'Accuracy - {model_name}')\n","    plt.legend()\n","\n","    # Plot Loss\n","    plt.subplot(1, 2, 2)\n","    plt.plot(epochs, loss, 'b', label='Training Loss')\n","    plt.plot(epochs, val_loss, 'r', label='Validation Loss')\n","    plt.title(f'Loss - {model_name}')\n","    plt.legend()\n","\n","    plt.show()\n","\n","def evaluate_model(model, X_test, y_test, label_names=['negatif', 'netral', 'positif']):\n","    \"\"\"Fungsi untuk menampilkan Classification Report dan Confusion Matrix\"\"\"\n","    y_pred = model.predict(X_test)\n","    y_pred_classes = np.argmax(y_pred, axis=1)\n","    y_true = np.argmax(y_test, axis=1)\n","\n","    print(\"\\n--- Classification Report ---\")\n","    print(classification_report(y_true, y_pred_classes, target_names=label_names))\n","\n","    # Confusion Matrix\n","    cm = confusion_matrix(y_true, y_pred_classes)\n","    plt.figure(figsize=(8, 6))\n","    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n","                xticklabels=label_names, yticklabels=label_names)\n","    plt.xlabel('Predicted')\n","    plt.ylabel('Actual')\n","    plt.title('Confusion Matrix')\n","    plt.show()"],"metadata":{"id":"T1AF5NuwD_Lw"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["## **5.2 Machine Learning Model**"],"metadata":{"id":"YRDN0jpZCWG5"}},{"cell_type":"code","source":["from sklearn.feature_extraction.text import TfidfVectorizer